# FastAPI backend (baked in at build time on Vercel/Netlify/GitHub Actions)
# Local: must match uvicorn --port (8000 or 8001). Production: https://your-api.onrender.com — no trailing slash.
# Copy to .env and restart Vite after changing.
VITE_API_BASE=http://localhost:8000

# GitHub Pages project site only: URL prefix for assets and routing, e.g. /Asklytics/ (leading + trailing slash)
# Leave unset for Vercel/Netlify root deploys and local dev.
# VITE_BASE_PATH=/Asklytics/
