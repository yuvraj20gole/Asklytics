ENVIRONMENT=dev
DATABASE_URL=sqlite:///./local.db
# Optional: only for ancillary PDF/table helpers; /ask uses rule-based SQL without this.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
QUERY_MAX_ROWS=200
BACKEND_URL=http://localhost:8000
# Production: comma-separated frontend URLs (required for browser login / uploads from Vercel, Pages, etc.)
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app,https://yuvraj20gole.github.io
CORS_ALLOW_ORIGINS=
